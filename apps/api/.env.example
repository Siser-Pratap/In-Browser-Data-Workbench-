# --- AI ---------------------------------------------------------------------
# Anthropic API key (required for the /ai endpoints; tests mock the client)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_EFFORT=medium
AI_MAX_TOKENS=2048
AI_DAILY_TOKEN_BUDGET=200000

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://workbench:workbench@localhost:5432/workbench
# Create tables on startup instead of running Alembic (dev only; use migrations otherwise)
DB_AUTO_CREATE=false

# --- Auth / security --------------------------------------------------------
# Generate a strong value in production (>= 32 bytes). Unset => a random one is
# generated at startup (tokens then don't survive a restart).
JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Over plain http (local dev) set this false so the refresh cookie is sent
COOKIE_SECURE=true

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# --- OAuth (optional; providers activate only when both id + secret are set) -
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000

# --- Platform ---------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
