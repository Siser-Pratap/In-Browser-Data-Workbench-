# Anthropic API key (required for the /ai endpoints; tests mock the client)
ANTHROPIC_API_KEY=

# Model + generation settings
AI_MODEL=claude-opus-4-8
AI_EFFORT=medium
AI_MAX_TOKENS=2048

# Per-user daily token budget for AI endpoints
AI_DAILY_TOKEN_BUDGET=200000

# Comma-separated origins allowed by CORS (the Next.js dev server)
CORS_ORIGINS=http://localhost:3000
